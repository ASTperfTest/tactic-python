(function()
{






 CKEDITOR.htmlParser.cdata = function( value )
 {
 




  this.value = value;
 };

 CKEDITOR.htmlParser.cdata.prototype =
 {
 





  type : CKEDITOR.NODE_TEXT,

 



  writeHtml : function( writer )
  {
   writer.write( this.value );
  }
 };
})();

 